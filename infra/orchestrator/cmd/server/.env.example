# Webhook server
PORT=8080
WEBHOOK_SECRET=your-github-webhook-secret

# Database
DATABASE_URL=postgres://orchestrator:changeme@postgres:5432/orchestrator?sslmode=disable

# --- Kanban Auth (optional — omit to disable auth endpoints) ---
GITHUB_OAUTH_CLIENT_ID=your_github_app_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_app_client_secret
COOKIE_SIGNING_SECRET=generate-a-random-32-char-string
KANBAN_ORIGIN=https://apeiron-orchestrator.lukemckechnie.com/kanban