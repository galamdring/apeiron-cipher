# n8n
N8N_HOST=n8n.yourdomain.com
N8N_ENCRYPTION_KEY=generate-a-random-32-char-string
GENERIC_TIMEZONE=America/Toronto

# n8n owner account (created on first startup by entrypoint.sh)
N8N_OWNER_EMAIL=admin@yourdomain.com
N8N_OWNER_PASSWORD=change-me-strong-password

# PostgreSQL (external, accessed via host.docker.internal)
DB_POSTGRESDB_PORT=5434
DB_POSTGRESDB_PASSWORD=change-me

# Cloudflare Tunnel
# Create at: https://one.dash.cloudflare.com → Networks → Tunnels → Create
# Point the tunnel's public hostname at http://n8n:5678
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# GitHub App authentication
# Create at: GitHub Settings → Developer Settings → GitHub Apps
# Required permissions: Issues (read/write), Contents (read), Metadata (read)
# Subscribe to webhook events: Issues, Issue comments
GITHUB_APP_ID=123456
GITHUB_INSTALLATION_ID=12345678
GITHUB_PRIVATE_KEY_BASE64=base64-encoded-pem-private-key

# Webhook signature verification (set in GitHub App webhook config)
GITHUB_WEBHOOK_SECRET=generate-a-random-string

# OpenRouter LLM API
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=

# Agent execution (Section 16)
# Graphite CLI token — required for gt submit (PR stacking)
# Get from: https://app.graphite.dev/activate
GT_TOKEN=
