{
  "name": "Router: GitHub Webhook",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "github-webhook",
        "options": {
          "rawBody": true
        }
      },
      "name": "GitHub Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        208,
        304
      ],
      "webhookId": "github-webhook",
      "id": "b487e628-6fb3-4e98-9990-2e60effb0cb3"
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst webhookSecret = $env.GITHUB_WEBHOOK_SECRET;\nconst signature = $input.first().json.headers['x-hub-signature-256'];\nconst rawBody = $input.first().json.body;\n\nif (!webhookSecret || !signature) {\n  return [{ json: { verified: false, reason: 'Missing secret or signature' } }];\n}\n\nconst expected = 'sha256=' + crypto\n  .createHmac('sha256', webhookSecret)\n  .update(JSON.stringify(rawBody))\n  .digest('hex');\n\nconst verified = crypto.timingSafeEqual(\n  Buffer.from(signature),\n  Buffer.from(expected)\n);\n\nreturn [{ json: { verified, ...($input.first().json) } }];"
      },
      "name": "Verify Signature",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        352,
        304
      ],
      "id": "cd32749e-ac63-4e55-b2b2-a81d2ce553ea"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
