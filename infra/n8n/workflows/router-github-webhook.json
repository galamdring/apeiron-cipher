      "id": "732f3de0-42a8-4808-9bab-137c689c8449"
    },
    {
      "parameters": {
        "jsCode": "const headers = $input.first().json.headers;\nconst body = $input.first().json.body;\n\nconst event = headers['x-github-event'] || '';\nconst action = body.action || '';\nconst senderLogin = body.sender?.login || '';\nconst senderType = body.sender?.type || '';\nconst commentUserLogin = body.comment?.user?.login || '';\nconst commentUserType = body.comment?.user?.type || '';\nconst isBot = senderType === 'Bot' || commentUserType === 'Bot' || senderLogin.endsWith('[bot]') || commentUserLogin.endsWith('[bot]');\nconst labels = (body.issue?.labels || []).map(l => l.name);\nconst labelAdded = body.label?.name || '';\n\n// Type labels\nconst hasEpic = labels.includes('epic');\nconst hasStory = labels.includes('story');\nconst hasBug = labels.includes('bug');\nconst hasTask = labels.includes('task');\nconst isEpicTitle = /^epic\\b/i.test(body.issue?.title || '');\n\n// Scoping labels\nconst hasNeedsRefinement = labels.includes('needs_refinement');\nconst hasInScoping = labels.includes('in_scoping');\nconst hasSowReady = labels.includes('sow_ready');\nconst hasStoriesCreated = labels.includes('stories_created');\n\n// Linking labels \u2014 check for any epic-N label\nconst epicNLabel = labels.find(l => /^epic-\\d+$/.test(l)) || '';\n\n// Phase 3 stubs\nconst isPRReviewComment = event === 'pull_request_review_comment' && action === 'created';\n\nlet route = 'ignore';\n\n// === issues.opened ===\nif (event === 'issues' && action === 'opened') {\n  if (isEpicTitle) {\n    route = 'epic-created';\n  } else if (hasStory) {\n    route = 'story-created';\n  } else if (isBot) {\n    route = 'bot-unlabeled';\n  } else {\n    route = 'user-issue';\n  }\n}\n\n// === issues.labeled (bot loop prevention: ignore bot label events) ===\nelse if (event === 'issues' && action === 'labeled' && !isBot) {\n  if (labelAdded === 'needs_refinement') {\n    if (hasEpic) route = 'epic-initial-refinement';\n    else if (hasBug) route = 'bug-diagnosis';\n    else if (hasTask) route = 'task-initial-refinement';\n  } else if (labelAdded === 'sow_ready') {\n    if (hasEpic) route = 'story-creation';\n    else if (hasTask) route = 'task-ready';\n  } else if (labelAdded === 'status:ready') {\n    if (hasEpic && hasStoriesCreated) route = 'ready-cascade';\n    else if (hasStory) route = 'agent-code-start';\n  }\n}\n\n// === issues.closed ===\nelse if (event === 'issues' && action === 'closed') {\n  if (hasStory && epicNLabel) {\n    route = 'story-close-check';\n  }\n}\n\n// === issue_comment (scoping conversations \u2014 human only) ===\nelse if (event === 'issue_comment' && (action === 'created' || action === 'edited') && !isBot) {\n  if (hasEpic && hasInScoping && !hasSowReady) {\n    route = 'epic-scoping';\n  } else if (hasTask && hasInScoping && !hasSowReady) {\n    route = 'task-scoping';\n  }\n}\n\n// === Phase 3 stubs ===\nelse if (isPRReviewComment) {\n  route = 'pr-review-feedback';\n}\n\nreturn [{\n  json: {\n    route,\n    event,\n    action,\n    isBot,\n    issueNumber: body.issue?.number || 0,\n    issueTitle: body.issue?.title || '',\n    issueBody: body.issue?.body || '',\n    issueNodeId: body.issue?.node_id || '',\n    repoOwner: body.repository?.owner?.login || '',\n    repoName: body.repository?.name || '',\n    labels,\n    labelAdded,\n    epicNLabel,\n    senderLogin,\n    senderType,\n    commentBody: body.comment?.body || '',\n    commentUser: body.comment?.user?.login || '',\n    headers,\n    body\n  }\n}];"
      },
